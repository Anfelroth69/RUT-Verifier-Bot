# Configuración para RUT Verifier Platform

# --- BACKEND ---
# Documento de identidad para iniciar sesión en la DIAN
DIAN_DOCUMENT=12345678

# Contraseña de la cuenta DIAN (Portal MUISCA)
DIAN_PASSWORD=TuPasswordSeguro

# Configuración del Navegador (True para servidores/Docker, False para ver el proceso en local)
PLAYWRIGHT_HEADLESS=True

# URL permitida para CORS (Generalmente la URL de tu frontend en Render o localhost)
FRONTEND_URL=http://localhost:4321

# --- FRONTEND ---
# URL de la API del Backend (Sin barra al final)
PUBLIC_API_URL=http://localhost:8000
