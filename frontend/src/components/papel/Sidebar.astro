---
// Papel Sidebar — Warm Approachable
---
<aside id="papel-sidebar" class="fixed inset-y-0 left-0 z-40 w-[75vw] max-w-sm bg-[#f0ede8] border-r border-stone-200 flex flex-col lg:shadow-none" data-open="false">
  <div class="p-5 border-b border-stone-200/60">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-green-700 flex items-center justify-center text-white font-bold font-mono text-sm tracking-tight shadow-sm">
        RUT
      </div>
      <div>
        <h1 class="text-base font-semibold text-stone-900 tracking-tight">RUT Verifier</h1>
        <p class="text-xs text-stone-500">Dashboard</p>
      </div>
    </div>
  </div>

  <nav class="flex-1 p-3 space-y-1" aria-label="Navegación principal">
    <button
      data-sidebar-item="individual"
      class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-green-700 bg-green-100/80 transition-all duration-200 hover:bg-green-100 text-left"
      aria-label="Verificación Individual"
    >
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
      <span>Verificación Individual</span>
    </button>

    <button
      data-sidebar-item="batch"
      class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-stone-500 hover:text-stone-800 hover:bg-stone-200/60 transition-all duration-200 text-left"
      aria-label="Verificación por Lote"
    >
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <span>Verificación por Lote</span>
    </button>
  </nav>

  <div class="p-3 border-t border-stone-200/60">
    <button
      data-sidebar-item="settings"
      class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-stone-500 hover:text-stone-800 hover:bg-stone-200/60 transition-all duration-200 text-left"
      aria-label="Ajustes"
    >
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      <span>Ajustes</span>
    </button>
  </div>
</aside>

<div id="sidebar-backdrop" class="fixed inset-0 z-30 bg-black lg:hidden" data-visible="false"></div>

<script>
  const sidebar = document.getElementById('papel-sidebar');
  const backdrop = document.getElementById('sidebar-backdrop');
  const menuBtn = document.getElementById('mobile-menu-btn');

  function openSidebar() {
    if (!sidebar || !backdrop) return;
    sidebar.setAttribute('data-open', 'true');
    backdrop.setAttribute('data-visible', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    if (!sidebar || !backdrop) return;
    sidebar.setAttribute('data-open', 'false');
    backdrop.setAttribute('data-visible', 'false');
    document.body.style.overflow = '';
  }

  menuBtn?.addEventListener('click', () => {
    if (sidebar?.getAttribute('data-open') === 'true') {
      closeSidebar();
    } else {
      openSidebar();
    }
  });

  backdrop?.addEventListener('click', closeSidebar);

  document.querySelectorAll('[data-sidebar-item]').forEach(item => {
    item.addEventListener('click', () => {
      const viewId = item.getAttribute('data-sidebar-item');
      const views: Record<string, HTMLElement | null> = {
        individual: document.querySelector('[data-view="individual"]'),
        batch: document.querySelector('[data-view="batch"]'),
      };
      const focusTargets: Record<string, string> = {
        individual: '#cedula',
        batch: '#bw-dropzone',
      };

      document.querySelectorAll('[data-sidebar-item]').forEach(el => {
        const id = el.getAttribute('data-sidebar-item');
        if (id === viewId) {
          el.className = 'w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-green-700 bg-green-100/80 transition-all duration-200 hover:bg-green-100 text-left';
        } else {
          el.className = 'w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-stone-500 hover:text-stone-800 hover:bg-stone-200/60 transition-all duration-200 text-left';
        }
      });

      Object.entries(views).forEach(([key, el]) => {
        if (el) {
          if (key === viewId) {
            el.classList.remove('hidden');
            el.style.animation = 'none';
            el.offsetHeight;
            el.style.animation = '';
            const target = document.querySelector(focusTargets[viewId]) as HTMLElement | null;
            target?.focus();
          } else {
            el.classList.add('hidden');
          }
        }
      });

      if (window.innerWidth < 1024) {
        closeSidebar();
      }
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSidebar();
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024) {
      backdrop?.setAttribute('data-visible', 'false');
      document.body.style.overflow = '';
    }
  });

  const defaultView = document.querySelector('[data-view="individual"]');
  if (defaultView) {
    defaultView.classList.remove('hidden');
  }
</script>
