---
// Papel ResultCard — Warm Approachable
---
<div id="result-container" class="mt-8 hidden"></div>

<template id="result-card-template">
  <div class="bg-white rounded-2xl shadow-[0_1px_3px_0_rgba(22,101,52,0.06)] border border-stone-200 transition-all duration-300">
    <div class="p-6">
      <div class="flex items-start justify-between">
        <div>
          <h2 class="text-lg font-semibold text-stone-900 mb-1">Resultado de la consulta</h2>
          <p class="text-sm text-stone-500">Cédula: <span class="font-medium text-stone-800 font-mono result-cedula"></span></p>
        </div>
        <div class="result-badge flex items-center px-3 py-1 rounded-full text-sm font-medium"></div>
      </div>
      <div class="mt-4 pt-4 border-t border-stone-100">
        <p class="text-stone-700 result-message"></p>
        <div class="result-data-container mt-4 bg-[#f5f0e8] p-4 rounded-xl border border-stone-200 hidden">
          <p class="text-xs text-stone-500 uppercase tracking-wider font-semibold mb-1">Contenido Confirmado</p>
          <p class="text-sm font-mono text-stone-800 result-content break-all"></p>
        </div>
      </div>
    </div>
    <div class="bg-[#f5f0e8] px-6 py-3 border-t border-stone-100 flex items-center text-xs text-stone-500">
      <svg class="w-4 h-4 mr-1 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      Tiempo de respuesta: <span class="result-duration ml-1 font-medium text-stone-700"></span> ms
    </div>
  </div>
</template>

<template id="history-item-template">
  <li class="py-3 flex items-center gap-3 border-b border-stone-100 last:border-0 hover:bg-[#f5f0e8] -mx-2 px-2 rounded-xl transition-colors">
    <div class="history-status-indicator w-2 h-2 rounded-full flex-shrink-0"></div>
    <div class="flex-1 min-w-0">
      <p class="text-sm font-medium text-stone-800 history-cedula font-mono"></p>
      <p class="text-xs text-stone-400 history-date"></p>
    </div>
    <div class="text-xs text-right text-stone-400 history-message max-w-[40%] truncate"></div>
  </li>
</template>

<template id="result-skeleton-template">
  <div class="bg-white rounded-2xl shadow-[0_1px_3px_0_rgba(22,101,52,0.06)] border border-stone-200 p-6 space-y-4">
    <div class="flex items-start justify-between">
      <div class="space-y-2 flex-1">
        <div class="h-5 w-48 rounded-lg animate-papel-shimmer"></div>
        <div class="h-4 w-32 rounded-lg animate-papel-shimmer"></div>
      </div>
      <div class="h-7 w-20 rounded-full animate-papel-shimmer"></div>
    </div>
    <div class="pt-4 border-t border-stone-100 space-y-2">
      <div class="h-4 w-full rounded-lg animate-papel-shimmer"></div>
      <div class="h-4 w-3/4 rounded-lg animate-papel-shimmer"></div>
    </div>
  </div>
</template>
