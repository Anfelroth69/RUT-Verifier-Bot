---
// Papel VerifyForm — Warm Approachable
---
<div class="bg-white p-6 sm:p-8 rounded-2xl shadow-[0_1px_3px_0_rgba(22,101,52,0.06),0_1px_2px_-1px_rgba(22,101,52,0.06)] border border-stone-200 animate-papel-fade-in-up" style="animation-duration: 0.5s">
  <form id="verify-form" class="space-y-5" novalidate>
    <div>
      <label for="cedula" class="block text-sm font-medium text-stone-700 mb-1">
        Número de Cédula
      </label>
      <div class="relative">
        <input
          type="text"
          id="cedula"
          name="cedula"
          required
          pattern="^\\d{6,10}$"
          placeholder="Ej: 16728423"
           class="block w-full rounded-xl border-stone-300 bg-white shadow-sm focus:border-green-700 focus:ring-2 focus:ring-green-700/10 focus:animate-papel-glow-pulse sm:text-sm px-4 py-3.5 border outline-none transition-all duration-200 peer text-stone-900
                  user-invalid:border-[#c2410c] user-invalid:text-[#c2410c] user-invalid:focus:border-[#c2410c] user-invalid:focus:ring-[#c2410c]/10 user-invalid:focus:animate-none"
        />
        <p class="mt-2 text-sm text-[#c2410c] hidden peer-user-invalid:block">
          Ingrese un número de cédula válido (solo números, 6-10 dígitos).
        </p>
      </div>
      <p class="mt-2 text-xs text-stone-400 peer-user-invalid:hidden">
        Ingrese el número sin puntos ni comas.
      </p>
    </div>

    <div id="cold-start-alert" class="hidden bg-green-50 border-l-4 border-green-700 p-4 rounded-xl">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-sm text-green-800">El servidor se está despertando tras un periodo de inactividad. Esto puede tomar un minuto...</p>
        </div>
      </div>
    </div>

    <div id="error-alert" class="hidden bg-orange-50 border-l-4 border-[#c2410c] p-4 rounded-xl">
      <div class="ml-3">
        <p class="text-sm text-stone-800" id="error-alert-text"></p>
      </div>
    </div>

    <button
      type="submit"
      id="submit-btn"
      class="w-full flex justify-center py-3.5 px-4 rounded-xl text-sm font-medium text-white bg-green-700 hover:bg-[#14532d] hover:-translate-y-[1px] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-700 disabled:opacity-70 disabled:cursor-not-allowed transition-all duration-200 active:scale-[0.97] active:translate-y-0 shadow-[0_1px_3px_0_rgba(22,101,52,0.15)]"
    >
      <span id="btn-text">Verificar RUT</span>
      <svg id="btn-spinner" class="hidden animate-spin ml-2 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </button>
  </form>
</div>

<script>
  import type { RutResponse, HistoryItem } from '../../types';

  const form = document.getElementById('verify-form') as HTMLFormElement;
  const inputCedula = document.getElementById('cedula') as HTMLInputElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLSpanElement;
  const btnSpinner = document.getElementById('btn-spinner') as HTMLElement;
  const coldStartAlert = document.getElementById('cold-start-alert') as HTMLDivElement;
  const errorAlert = document.getElementById('error-alert') as HTMLDivElement;
  const errorAlertText = document.getElementById('error-alert-text') as HTMLParagraphElement;
  const resultContainer = document.getElementById('result-container') as HTMLDivElement;
  const historyList = document.getElementById('history-list') as HTMLUListElement;
  const emptyHistory = document.getElementById('empty-history') as HTMLParagraphElement;

  const API_URL = import.meta.env.PUBLIC_API_URL || "";

  const loadHistory = () => {
    const historyData = localStorage.getItem('rutHistory');
    if (!historyData) return [];
    try { return JSON.parse(historyData) as HistoryItem[]; }
    catch { return []; }
  };

  const saveHistory = (item: HistoryItem) => {
    const history = loadHistory();
    const filteredHistory = history.filter(h => h.cedula !== item.cedula);
    const newHistory = [item, ...filteredHistory].slice(0, 10);
    localStorage.setItem('rutHistory', JSON.stringify(newHistory));
    renderHistory();
  };

  const renderHistory = () => {
    const history = loadHistory();
    if (!historyList) return;
    historyList.innerHTML = '';
    if (history.length === 0) { if (emptyHistory) emptyHistory.classList.remove('hidden'); return; }
    if (emptyHistory) emptyHistory.classList.add('hidden');
    const template = document.getElementById('history-item-template') as HTMLTemplateElement;
    history.forEach(item => {
      const clone = template.content.cloneNode(true) as DocumentFragment;
      const dot = clone.querySelector('.history-status-indicator') as HTMLDivElement;
      if (item.rut_exists === true) dot.classList.add('bg-green-600');
      else if (item.rut_exists === false) dot.classList.add('bg-[#c2410c]');
      else dot.classList.add('bg-amber-700');
      (clone.querySelector('.history-cedula') as HTMLParagraphElement).textContent = item.cedula;
      (clone.querySelector('.history-date') as HTMLParagraphElement).textContent = new Date(item.timestamp).toLocaleString('es-CO');
      (clone.querySelector('.history-message') as HTMLDivElement).textContent = item.message || "Error";
      historyList.appendChild(clone);
    });
  };

  const renderResult = (res: RutResponse, cedula: string) => {
    resultContainer.innerHTML = '';
    resultContainer.classList.remove('hidden');
      resultContainer.style.animation = 'papel-slide-in-right 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
    const template = document.getElementById('result-card-template') as HTMLTemplateElement;
    const clone = template.content.cloneNode(true) as DocumentFragment;
    (clone.querySelector('.result-cedula') as HTMLSpanElement).textContent = cedula;
    (clone.querySelector('.result-message') as HTMLParagraphElement).textContent = res.message;
    (clone.querySelector('.result-duration') as HTMLSpanElement).textContent = res.duration_ms.toString();
    const badge = clone.querySelector('.result-badge') as HTMLDivElement;
    if (res.status === 'success' && res.rut_exists === true) {
      badge.innerHTML = `<svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg> RUT Activo`;
      badge.classList.add('bg-green-100', 'text-green-800');
      if (res.data) {
        const dataContainer = clone.querySelector('.result-data-container') as HTMLDivElement;
        dataContainer.classList.remove('hidden');
        (clone.querySelector('.result-content') as HTMLParagraphElement).textContent = res.data.contenido_confirmado;
      }
    } else if (res.status === 'success' && res.rut_exists === false) {
      badge.innerHTML = `<svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg> Sin RUT`;
      badge.classList.add('bg-orange-100', 'text-orange-800');
    } else {
      badge.innerHTML = `<svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg> Error`;
      badge.classList.add('bg-amber-100', 'text-amber-800');
    }
    resultContainer.appendChild(clone);
  };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) return;
    const cedula = inputCedula.value.trim();
    submitBtn.disabled = true;
    btnText.textContent = "Verificando...";
    btnSpinner.classList.remove('hidden');
    coldStartAlert.classList.add('hidden');
    errorAlert.classList.add('hidden');
    resultContainer.classList.add('hidden');
    const coldStartTimer = setTimeout(() => { coldStartAlert.classList.remove('hidden'); }, 5000);
    try {
      const controller = new AbortController();
      const fetchTimeout = setTimeout(() => controller.abort(), 90000);
      const response = await fetch(`${API_URL}/api/v1/verify`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ cedula }), signal: controller.signal
      });
      clearTimeout(fetchTimeout);
      if (!response.ok) { const errData = await response.json().catch(() => ({})); throw new Error(errData.detail || `Error HTTP: ${response.status}`); }
      const data = await response.json() as RutResponse;
      renderResult(data, cedula);
      saveHistory({ cedula, timestamp: new Date().toISOString(), rut_exists: data.rut_exists, message: data.message, data: data.data });
    } catch (error: any) {
      if (error.name === 'AbortError') errorAlertText.textContent = "La petición ha excedido el tiempo de espera (90s).";
      else if (error.message === 'Failed to fetch') errorAlertText.textContent = "No se pudo conectar con el servidor.";
      else errorAlertText.textContent = `Error: ${error.message}`;
      errorAlert.classList.remove('hidden');
      errorAlert.style.animation = 'none';
      errorAlert.offsetHeight;
      errorAlert.style.animation = 'papel-shake 0.4s ease-in-out';
    } finally {
      clearTimeout(coldStartTimer);
      coldStartAlert.classList.add('hidden');
      submitBtn.disabled = false;
      btnText.textContent = "Verificar RUT";
      btnSpinner.classList.add('hidden');
    }
  });

  document.addEventListener('DOMContentLoaded', renderHistory);
</script>
