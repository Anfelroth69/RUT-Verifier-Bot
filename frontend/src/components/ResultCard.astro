---
// ResultCard.astro
// Este componente provee el contenedor y el template HTML para los resultados.
---
<div id="result-container" class="mt-8 hidden">
  <!-- El resultado se inyectará aquí mediante JavaScript -->
</div>

<template id="result-card-template">
  <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100 transition-all duration-300">
    <div class="p-6">
      <div class="flex items-start justify-between">
        <div>
          <h2 class="text-lg font-semibold text-gray-900 mb-1">Resultado de la consulta</h2>
          <p class="text-sm text-gray-500">Cédula: <span class="font-medium text-gray-900 result-cedula"></span></p>
        </div>
        <div class="result-badge flex items-center px-3 py-1 rounded-full text-sm font-medium">
          <!-- Badge text and color applied via JS -->
        </div>
      </div>
      
      <div class="mt-4 pt-4 border-t border-gray-100">
        <p class="text-gray-700 result-message"></p>
        
        <div class="result-data-container mt-4 bg-gray-50 p-4 rounded-lg hidden">
          <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-1">Contenido Confirmado</p>
          <p class="text-sm font-mono text-gray-800 result-content break-all"></p>
        </div>
      </div>
    </div>
    <div class="bg-gray-50 px-6 py-3 border-t border-gray-100 flex justify-between items-center text-xs text-gray-500">
      <span class="flex items-center">
        <svg class="w-4 h-4 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        Tiempo de respuesta: <span class="result-duration ml-1 font-medium"></span> ms
      </span>
    </div>
  </div>
</template>

<template id="history-item-template">
  <li class="py-3 flex justify-between items-center border-b border-gray-100 last:border-0">
    <div class="flex items-center">
      <div class="history-status-indicator w-2 h-2 rounded-full mr-3"></div>
      <div>
        <p class="text-sm font-medium text-gray-900 history-cedula"></p>
        <p class="text-xs text-gray-500 history-date"></p>
      </div>
    </div>
    <div class="text-xs text-right text-gray-600 history-message max-w-[50%] truncate"></div>
  </li>
</template>
